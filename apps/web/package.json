    "axios": "^1.18.1",
    "daisyui": "^5.6.18",
    "expo": "~56.0.4",
    "expo-location": "~56.0.21",
    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-sensors": "~56.0.6",
    "expo-splash-screen": "~56.0.10",
